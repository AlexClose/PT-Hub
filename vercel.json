{
  "routes": [
    { "src": "/alex", "dest": "/alex.html" },
    { "src": "/kathryn", "dest": "/kathryn.html" },
    { "src": "/test", "dest": "/test.html" },
    { "src": "/", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src * 'unsafe-inline' 'unsafe-eval' data: blob:;"
        }
      ]
    }
  ]
}
